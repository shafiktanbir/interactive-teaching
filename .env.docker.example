# Copy to .env.local on the VPS (GitHub Actions deploy does this automatically).
# For local `docker compose`, copy `MONGO_INITDB_ROOT_*` into a project root `.env` (or
# symlink `.env.local` to `.env`) so Compose can substitute them into the backend MONGODB_URI.
# Mongo (must match MONGODB_URI credentials)
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=change_me_strong

# Backend — use service name `mongo` on the Docker network
MONGODB_URI=mongodb://root:change_me_strong@mongo:27017/interactive?authSource=admin

# Public browser origin (your real domain)
CORS_ORIGINS=https://your-domain.example,*

MEDIA_URL_ALLOWLIST=picsum.photos,www.youtube.com,youtube.com,*

# Published to host loopback only (host nginx proxies here)
FRONTEND_PUBLISH_PORT=8080
BACKEND_PUBLISH_PORT=8000
