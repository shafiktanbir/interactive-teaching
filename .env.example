# Copy to repo root `.env` (make setup-env does this) so Docker Compose uses the same
# Mongo credentials as the backend. `MONGO_INITDB_*` apply only on first DB init; if you
# change the password here after Mongo already has data, either set MONGODB_URI to match
# the existing admin user or reset the volume: `docker compose down -v` (wipes DB).

# MongoDB (used by docker compose for the mongo service)
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=interactive

# Backend — must match MONGO_INITDB_* above (same user/password)
MONGODB_URI=mongodb://root:interactive@localhost:27017/interactive?authSource=admin

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

# External media URLs must match one of these host suffixes (comma-separated).
# Leave empty to block all external URLs (inline DB content still works).
MEDIA_URL_ALLOWLIST=picsum.photos,www.youtube.com,youtube.com

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000
